# interface/.dev.vars — local wrangler dev overrides (gitignored)
# Copy to .dev.vars and fill in values. Never commit .dev.vars.
#
# Same-machine dev (wrangler dev + npm run serve in safety-quotient/):
PSQ_ENDPOINT_URL=http://127.0.0.1:3000
#
# CF Tunnel (smoke test / cross-machine dev):
# PSQ_ENDPOINT_URL=https://your-tunnel-url.trycloudflare.com
#
# Production VPS (Option B):
# PSQ_ENDPOINT_URL=https://your-vps-hostname/
#
# ANTHROPIC_API_KEY=sk-ant-...   # /turn deferred — set when API credits available
